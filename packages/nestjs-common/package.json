{
  "name": "@assertly/nestjs-common",
  "version": "0.0.1",
  "license": "AGPL-3.0-only",
  "description": "Shared NestJS utilities for Assertly services",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing/throttle-test.helper.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/throttle-test.helper.d.ts",
      "default": "./dist/testing/throttle-test.helper.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@assertly/shared-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/terminus": "^11.1.1",
    "jose": "^6.0.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@assertly/database": "workspace:*",
    "@fastify/helmet": "^13.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@outboxy/dialect-postgres": "^1.1.4",
    "drizzle-orm": ">=0.45.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@assertly/typescript-config": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.0.0",
    "drizzle-orm": "^0.45.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
