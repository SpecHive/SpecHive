{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    // Source code uses ESM syntax; CJS is compiler output only.
    // NestJS 11 ESM support requires non-trivial bootstrapping changes,
    // so we intentionally compile to CommonJS for now.
    "module": "CommonJS",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "lib": ["ES2022"]
  }
}
