{
  "name": "@assertly/reporter-core-protocol",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Core event protocol definitions for Assertly reporters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/assertly-dev/assertly",
    "directory": "packages/reporter-core-protocol"
  },
  "keywords": [
    "assertly",
    "reporter",
    "protocol",
    "events",
    "test-reporting"
  ],
  "dependencies": {
    "@assertly/shared-types": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@assertly/typescript-config": "workspace:*",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
