{
  "name": "@assertly/database",
  "version": "0.0.1",
  "description": "Database schema, connection, and migrations for Assertly",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "db:generate": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "perf:baseline": "tsx src/perf-baseline.ts"
  },
  "dependencies": {
    "@assertly/shared-types": "workspace:*",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@assertly/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
