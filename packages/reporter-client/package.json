{
  "name": "@spechive/reporter-client",
  "version": "0.0.4",
  "description": "Shared HTTP client, queue, config, and CI detection for SpecHive reporters",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@spechive/reporter-core-protocol": "workspace:*",
    "@spechive/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@spechive/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
