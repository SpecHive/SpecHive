# =============================================================================
# Assertly environment variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=assertly
POSTGRES_PASSWORD=assertly
POSTGRES_DB=assertly

# Full connection string used by application services (restricted role, subject to RLS)
DATABASE_URL=postgres://assertly_app:assertly_app@localhost:5432/assertly

# Password for the assertly_app role (used in docker-compose env var substitution)
ASSERTLY_APP_PASSWORD=assertly_app

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Used by application code to connect to MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=assertly-artifacts
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# ingestion-api  (port 3000)
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Shared secret for authenticating Outboxy webhook deliveries to the worker
WEBHOOK_SECRET=change-me-in-production

# Internal URL to the worker's outboxy webhook endpoint
WORKER_WEBHOOK_URL=http://localhost:3001/webhooks/outboxy

# Internal URL to the Outboxy REST API
OUTBOXY_API_URL=http://localhost:3100

# -----------------------------------------------------------------------------
# worker  (port 3001)
# -----------------------------------------------------------------------------
# PORT=3001  (set per-service; share DATABASE_URL above)

# -----------------------------------------------------------------------------
# Outboxy (transactional outbox)
# -----------------------------------------------------------------------------
# API server port (used inside Docker network; exposed on host as 3100)
OUTBOXY_PORT=3100

# Worker delivery target — must point to the worker service webhook handler
PUBLISHER_TYPE=http
PUBLISHER_HTTP_DEFAULT_URL=http://localhost:3001/webhooks/outboxy

# -----------------------------------------------------------------------------
# dashboard  (port 5173)
# -----------------------------------------------------------------------------
# Vite inlines this at build time
VITE_API_URL=http://localhost:3000
