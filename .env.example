# SpecHive — cp this file to .env and fill in the values
#
# Ports: gateway=3000  ingestion-api=3001  worker=3002  query-api=3003  dashboard=5173

# === Infrastructure ===========================================================

# PostgreSQL
POSTGRES_USER=spechive
POSTGRES_PASSWORD=spechive
POSTGRES_DB=spechive
DATABASE_URL=postgres://spechive_app:spechive_app@localhost:5432/spechive  # docker-compose overrides to postgres:5432
SPECHIVE_APP_PASSWORD=spechive_app   # must match password in DATABASE_URL
OUTBOXY_PASSWORD=outboxy

# MinIO (S3-compatible storage)  [ingestion-api, query-api, worker]
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000          # internal; docker-compose overrides to minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000   # CDN/proxy URL in prod
MINIO_BUCKET=spechive-artifacts
MINIO_APP_ACCESS_KEY=spechive-app
MINIO_APP_SECRET_KEY=spechive-app-secret-key
MINIO_USE_SSL=false
S3_REGION=us-east-1
# MINIO_PUBLIC_USE_SSL=false           # set true if CDN terminates TLS

# Redis
REDIS_URL=redis://localhost:6379       # [query-api, worker] docker-compose overrides to redis:6379

# === Shared across services ===================================================

CORS_ORIGIN=http://localhost:5173                                                # [ingestion-api, query-api, gateway]
JWT_SECRET=local-dev-jwt-secret-key-this-should-be-at-least-64-characters-long-for-prod!!!!!  # [query-api, gateway] min 64 in prod
WEBHOOK_SECRET=change-me-in-production-min-32ch                                  # [ingestion-api, worker] min 32 chars
TOKEN_HASH_KEY=local-dev-token-hash-key-minimum-32-characters!!                  # [ingestion-api] min 32 chars

# === Per-service config =======================================================

# --- ingestion-api (:3001) ----------------------------------------------------
WORKER_URL=http://localhost:3002       # docker-compose overrides to http://worker:3002

# --- query-api (:3003) --------------------------------------------------------
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- worker (:3002) -----------------------------------------------------------
ARTIFACT_RETENTION_DAYS=90

# --- gateway (:3000) ----------------------------------------------------------
INGESTION_API_URL=http://localhost:3001  # docker-compose overrides to http://ingestion-api:3001
QUERY_API_URL=http://localhost:3003     # docker-compose overrides to http://query-api:3003

# --- dashboard (:5173) --------------------------------------------------------
VITE_API_URL=http://localhost:3000     # inlined by Vite at build time

# --- Seed data (local dev only) -----------------------------------------------
SEED_DATABASE_URL=postgres://spechive:spechive@localhost:5432/spechive
SEED_USER_PASSWORD=changeme

# === Observability =============================================================
# /metrics is served on port 9464 (fixed — see packages/nestjs-common/src/metrics/metrics.constants.ts)
# SERVICE_NAME=gateway                            # Service identity — metrics label + Loki stream (per-app default in env.validation.ts)
# METRICS_ENABLED=false                           # Opt-out: disables both /metrics and Node.js runtime metrics (GC, heap, event loop lag). Default: enabled — required by EventLoopBlocked + HighMemoryUsage alerts.
# METRICS_BIND_ADDR=127.0.0.1                     # /metrics listen address. Default '0.0.0.0' (safe when only private networks reach 9464, as with Docker Compose `internal` net or Railway private networking). Set to '127.0.0.1' when deploying without a private network front — metrics have no auth.
# LOKI_HOST=http://loki:3100                     # Loki push API base URL
# Note: For local dev with docker-compose.dev.yml, LOKI_HOST and SERVICE_NAME are set automatically

# === Observability — Grafana / Prometheus ======================================
GRAFANA_ADMIN_PASSWORD=changeme                         # Grafana admin password (dev override sets "admin")
SLACK_WEBHOOK_URL=http://localhost:9999/dev-null        # Warning-tier alerts channel (routine Slack).
SLACK_URGENT_WEBHOOK_URL=http://localhost:9999/dev-null # Critical/paging channel — point at a Slack channel with phone notifications or a Slack→PagerDuty bridge. Must not equal SLACK_WEBHOOK_URL in production or the critical/warning separation is lost.

# Prometheus scrape targets and Grafana datasource URLs are env-driven so the same
# image runs on docker-compose / Railway / K8s. Set per-environment in docker-compose.yml
# or your deploy target; container fails-loud at startup if any required var is missing.
# See docker/prometheus/entrypoint.sh and docker/grafana/provisioning/datasources/datasource.yml.
# Examples (docker-compose values; Railway uses *.railway.internal hostnames):
#   GATEWAY_HOST=gateway:9464
#   INGESTION_API_HOST=ingestion-api:9464
#   WORKER_HOST=worker:9464
#   QUERY_API_HOST=query-api:9464
#   OUTBOXY_HOST=outboxy-worker:9090
#   PROMETHEUS_URL=http://prometheus:9090
#   LOKI_URL=http://loki:3100

# --- Build secrets (CI only) --------------------------------------------------
# NPM_TOKEN=
