# =============================================================================
# SpecHive environment variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=spechive
# REQUIRED in production — no default is applied; the compose file will refuse
# to start if this is unset.
POSTGRES_PASSWORD=spechive
POSTGRES_DB=spechive

# Full connection string used by application services (restricted role, subject to RLS)
DATABASE_URL=postgres://spechive_app:spechive_app@localhost:5432/spechive

# Password for the spechive_app role (used in docker-compose env var substitution)
SPECHIVE_APP_PASSWORD=spechive_app

# Key used for argon2 token hashing context (min 32 chars in production)
TOKEN_HASH_KEY=local-dev-token-hash-key-minimum-32-characters!!

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
# REQUIRED in production — no default is applied; the compose file will refuse
# to start if this is unset.
MINIO_ROOT_PASSWORD=minioadmin

# Used by application code to connect to MinIO
MINIO_ENDPOINT=localhost:9000

# Public endpoint for presigned URLs returned to clients (browser downloads).
# In Docker, this is localhost:9000 while MINIO_ENDPOINT is minio:9000 (internal).
# In production, set this to your CDN or reverse proxy URL.
MINIO_PUBLIC_ENDPOINT=localhost:9000

MINIO_BUCKET=spechive-artifacts

# Scoped MinIO service account for application access (created by docker/minio/init.sh)
MINIO_APP_ACCESS_KEY=spechive-app
MINIO_APP_SECRET_KEY=spechive-app-secret-key
MINIO_USE_SSL=false

# AWS region for S3 SDK client (used with MinIO in S3-compatibility mode)
S3_REGION=us-east-1
# SSL for public presigned URLs. Defaults to MINIO_USE_SSL if not set.
# Set to 'true' if your CDN/proxy terminates TLS but internal MinIO is plain HTTP.
# MINIO_PUBLIC_USE_SSL=false

# -----------------------------------------------------------------------------
# ingestion-api  (port 3000)
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Shared secret for authenticating Outboxy webhook deliveries to the worker.
# REQUIRED — must be at least 32 characters in production.
# Min 32 characters required
WEBHOOK_SECRET=change-me-in-production-min-32ch

# Internal URL to the worker's outboxy webhook endpoint
WORKER_WEBHOOK_URL=http://localhost:3001/webhooks/outboxy

# Internal URL to the Outboxy REST API
OUTBOXY_API_URL=http://localhost:3100

# -----------------------------------------------------------------------------
# query-api  (port 3002)
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens for dashboard authentication.
# Must be at least 64 characters in production.
JWT_SECRET=local-dev-jwt-secret-key-this-should-be-at-least-64-characters-long-for-prod!!!!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# worker  (port 3001)
# -----------------------------------------------------------------------------
# PORT=3001  (set per-service; share DATABASE_URL above)

# Number of days to retain artifacts before automatic cleanup (default: 90)
ARTIFACT_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# gateway  (port 3003)
# -----------------------------------------------------------------------------
# Internal URLs for upstream services (Docker overrides these in compose)
INGESTION_API_URL=http://localhost:3000
QUERY_API_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# Build secrets (CI / Docker)
# -----------------------------------------------------------------------------
# Required for Docker builds and CI when using private npm packages.
# Not needed for local development with pnpm install.
# NPM_TOKEN=

# -----------------------------------------------------------------------------
# Outboxy database role
# -----------------------------------------------------------------------------
# Password for the dedicated outboxy Postgres role (used by outboxy-api and outboxy-worker)
OUTBOXY_PASSWORD=outboxy

# -----------------------------------------------------------------------------
# dashboard  (port 5173)
# -----------------------------------------------------------------------------
# Vite inlines this at build time
VITE_API_URL=http://localhost:3002

# Dashboard public URL (required in production, used for invite links and email templates)
DASHBOARD_URL=http://localhost:5173

# Integration test overrides (defaults used if not set)
# INGESTION_API_URL=http://localhost:3000
# QUERY_API_URL=http://localhost:3002
# WORKER_URL=http://localhost:3001
# ADMIN_DATABASE_URL=postgres://spechive:spechive@localhost:5432/spechive
# PROJECT_TOKEN=test-token
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
